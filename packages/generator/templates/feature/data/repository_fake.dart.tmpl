  @override
  Future<Either<Failure, {{Module}}Entity>> getById(String id) async {
    final i = _items.indexWhere((m) => m.id == id);
    if (i < 0) return Left(NotFoundFailure('No {{Module}} with id $id'));
    return Right(_items[i].toEntity());
  }

  @override
  Future<Either<Failure, {{Module}}Entity>> add({{Module}}Entity entity) async {
    final assignedId =
        entity.id.isEmpty ? '{{module_snake}}_${_nextId++}' : entity.id;
    final model = {{Module}}Model.fromEntity(entity.copyWith(id: assignedId));
    _items.add(model);
    return Right(model.toEntity());
  }

  @override
  Future<Either<Failure, {{Module}}Entity>> update({{Module}}Entity entity) async {
    final i = _items.indexWhere((m) => m.id == entity.id);
    if (i < 0) {
      return Left(NotFoundFailure('No {{Module}} with id ${entity.id}'));
    }
    final model = {{Module}}Model.fromEntity(entity);
    _items[i] = model;
    return Right(model.toEntity());
  }

  @override
  Future<Either<Failure, Unit>> delete(String id) async {
    final before = _items.length;
    _items.removeWhere((m) => m.id == id);
    if (_items.length == before) {
      return Left(NotFoundFailure('No {{Module}} with id $id'));
    }
    return const Right(unit);
  }

  // #if features.search
  @override
  Future<Either<Failure, List<{{Module}}Entity>>> search(String query) async {
    final q = query.toLowerCase();
    final hits = _items
        .where((m) =>
            (m.name ?? '').toLowerCase().contains(q) ||
            (m.description ?? '').toLowerCase().contains(q))
        .map((m) => m.toEntity())
        .toList(growable: false);
    return Right(hits);
  }
  // #endif
}
