/// In-memory {{Module}} repository for development, demos, and tests.
///
/// State is held in a private list — call [seeded] to bootstrap with mock
/// data, or pass [initial] explicitly.
class {{Module}}RepositoryFake implements {{Module}}Repository {
  {{Module}}RepositoryFake({List<{{Module}}Model>? initial})
      : _items = [...?initial];

  // #if features.mock_data_generation
  factory {{Module}}RepositoryFake.seeded({int count = 10}) =>
      {{Module}}RepositoryFake(initial: {{Module}}Model.dummyList(count));
  // #endif

  final List<{{Module}}Model> _items;
  var _nextId = 1000;

  @override
  Future<Either<Failure, List<{{Module}}Entity>>> getAll() async {
    return Right(_items.map((m) => m.toEntity()).toList(growable: false));
  }

  // #if features.pagination
  @override
  Future<Either<Failure, PaginatedResponse<{{Module}}Entity>>> getAllPaginated(
    PaginationParams params,
  ) async {
    final start = params.offset.clamp(0, _items.length);
    final end = (params.offset + params.limit).clamp(0, _items.length);
    final slice = _items
        .sublist(start, end)
        .map((m) => m.toEntity())
        .toList(growable: false);
    return Right(PaginatedResponse<{{Module}}Entity>(
      items: slice,
      total: _items.length,
      offset: params.offset,
      limit: params.limit,
    ));
  }
  // #endif

// #if features.filters
