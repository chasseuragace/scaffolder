/// List page for {{Module}}.
import React from 'react';
import { useNavigate } from 'react-router-dom';
// #if features.pagination
import { use{{Module}}ListInfinite, use{{Module}}Mutations } from '../hooks/{{module-kebab}}.hooks';
// #else
import { use{{Module}}List, use{{Module}}Mutations } from '../hooks/{{module-kebab}}.hooks';
// #endif
import { ErrorView } from '../../../../core/components/error-view';
import { EmptyView } from '../../../../core/components/empty-view';
import { ConfirmationDialog } from '../../../../core/components/confirmation-dialog';
// #if features.shimmer_loading
import { ShimmerTileList } from '../../../../core/components/shimmer-tile';
// #endif
import { {{Module}}ItemRow } from '../components/{{module-kebab}}-item-row';
// #if features.forms
import { {{Module}}FormDialog } from '../components/{{module-kebab}}-form-dialog';
// #endif

export function {{Module}}ListPage() {
  const navigate = useNavigate();

// #if features.success_feedback
  const [successMessage, setSuccessMessage] = React.useState<string | null>(null);
  React.useEffect(() => {
    if (!successMessage) return;
    const t = setTimeout(() => setSuccessMessage(null), 3000);
    return () => clearTimeout(t);
  }, [successMessage]);
  const { add, delete: deleteMutation } = use{{Module}}Mutations({ onSuccess: setSuccessMessage });
// #else
  const { add, delete: deleteMutation } = use{{Module}}Mutations();
// #endif

// #if features.pagination
  const { data: pages, isLoading, error, fetchNextPage, hasNextPage, isFetchingNextPage } = use{{Module}}ListInfinite();
  const data = pages?.pages.flatMap((p) => p.items) ?? [];
  const refetch = () => {};
// #else
  const { data, isLoading, error, refetch } = use{{Module}}List();
// #endif

// #if features.forms
  const [isFormOpen, setIsFormOpen] = React.useState(false);
// #endif

  /// Confirmation dialog state — replaces browser confirm() which blocks the event loop.
  const [deleteTargetId, setDeleteTargetId] = React.useState<string | null>(null);
  const handleDeleteConfirm = () => {
    if (deleteTargetId) {
      deleteMutation.mutate(deleteTargetId);
      setDeleteTargetId(null);
    }
  };

  if (isLoading) {
// #if features.shimmer_loading
    return <ShimmerTileList />;
// #else
    return <div className="flex justify-center p-8">Loading...</div>;
// #endif
  }

  if (error) {
    return <ErrorView message={error.message} onRetry={() => refetch()} />;
  }

  if (!data || data.length === 0) {
    return <EmptyView message="No {{Module}}s yet" />;
  }

  return (
    <div className="container mx-auto p-4">
      <div className="mb-4 flex items-center justify-between">
        <h1 className="text-2xl font-bold">{{Module}}s</h1>
        <div className="space-x-2">
          <button
            onClick={() => refetch()}
            className="rounded border px-4 py-2 hover:bg-gray-100"
          >
            Refresh
          </button>
// #if features.forms
          <button
            onClick={() => setIsFormOpen(true)}
            className="rounded bg-blue-500 px-4 py-2 text-white hover:bg-blue-600"
          >
            Add {{Module}}
          </button>
// #endif
        </div>
      </div>

      <div className="space-y-2">
        {data.map((item) => (
          <{{Module}}ItemRow
            key={item.id}
            item={item}
            onView={() => navigate(`/{{module-kebab}}/${item.id}`)}
            onDelete={() => setDeleteTargetId(item.id)}
          />
        ))}
      </div>

// #if features.pagination
      {hasNextPage && (
        <div className="mt-4 flex justify-center">
          <button
            onClick={() => fetchNextPage()}
            disabled={isFetchingNextPage}
            className="rounded border px-6 py-2 hover:bg-gray-100 disabled:opacity-50"
          >
            {isFetchingNextPage ? 'Loading…' : 'Load more'}
          </button>
        </div>
      )}
// #endif

// #if features.forms
      {isFormOpen && (
        <{{Module}}FormDialog
          isOpen={isFormOpen}
          onClose={() => setIsFormOpen(false)}
          onSave={(entity) => {
            add.mutate(entity);
            setIsFormOpen(false);
          }}
        />
      )}
// #endif

      <ConfirmationDialog
        isOpen={deleteTargetId !== null}
        title="Delete {{Module}}"
        message="Are you sure you want to delete this {{Module}}? This action cannot be undone."
        confirmText="Delete"
        onConfirm={handleDeleteConfirm}
        onCancel={() => setDeleteTargetId(null)}
      />

// #if features.success_feedback
      {successMessage && (
        <div className="fixed bottom-4 right-4 rounded bg-green-500 px-4 py-2 text-white shadow-lg">
          {successMessage}
        </div>
      )}
// #endif
    </div>
  );
}
