/// TanStack Query hooks for {{Module}}.
///
/// Fixes vs v1:
///   - use cases memoised (stable instance, no allocation per render)
///   - pagination uses useInfiniteQuery (real infinite-scroll)
///   - optimistic_updates flag wires onMutate/onError rollback
///   - success_feedback callbacks exposed so pages can show toasts
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
// #if features.pagination
import { useInfiniteQuery } from '@tanstack/react-query';
// #endif
import type { UseQueryResult } from '@tanstack/react-query';
import { useMemo } from 'react';
import type { {{Module}}Entity } from '../../domain/entities/{{module-kebab}}.entity';
import type { {{Module}}Repository } from '../../domain/repositories/{{module-kebab}}.repository';
import {
  GetAll{{Module}}sUseCase,
  Get{{Module}}ByIdUseCase,
  Add{{Module}}UseCase,
  Update{{Module}}UseCase,
  Delete{{Module}}UseCase,
} from '../../domain/usecases/{{module-kebab}}.usecases';
// #if features.search
import { Search{{Module}}sUseCase } from '../../domain/usecases/{{module-kebab}}.usecases';
// #endif
// #if features.pagination
import { GetAll{{Module}}sPaginatedUseCase } from '../../domain/usecases/{{module-kebab}}.usecases';
// #endif
import { use{{Module}}RepositoryContext } from '../{{module-kebab}}.repository-context';

/// Stable string key — avoids accidental collision with other features.
const QUERY_KEY = '{{module-kebab}}' as const;

export function use{{Module}}Repository(): {{Module}}Repository {
  return use{{Module}}RepositoryContext();
}

// ---------------------------------------------------------------------------
// Queries
// ---------------------------------------------------------------------------

export function use{{Module}}List(): UseQueryResult<{{Module}}Entity[], Error> {
  const repository = use{{Module}}Repository();
  const useCase = useMemo(() => new GetAll{{Module}}sUseCase(repository), [repository]);
  return useQuery({
    queryKey: [QUERY_KEY],
    queryFn: () =>
      useCase.execute().then((result) => {
        if ('left' in result) throw new Error(result.left.message);
        return result.right;
      }),
  });
}

// #if features.pagination
/// Infinite-scroll paginated list.
/// Consumers: `data.pages.flatMap(p => p.items)`, `fetchNextPage`, `hasNextPage`.
const PAGE_SIZE = 20;

export function use{{Module}}ListInfinite() {
  const repository = use{{Module}}Repository();
  const useCase = useMemo(() => new GetAll{{Module}}sPaginatedUseCase(repository), [repository]);
  return useInfiniteQuery({
    queryKey: [QUERY_KEY, 'infinite'],
    queryFn: ({ pageParam }) =>
      useCase.execute({ offset: pageParam as number, limit: PAGE_SIZE }).then((result) => {
        if ('left' in result) throw new Error(result.left.message);
        return result.right;
      }),
    initialPageParam: 0,
    getNextPageParam: (lastPage) => {
      const fetched = lastPage.offset + lastPage.items.length;
      return fetched < lastPage.total ? fetched : undefined;
    },
  });
}
// #endif

export function use{{Module}}ById(id: string): UseQueryResult<{{Module}}Entity, Error> {
  const repository = use{{Module}}Repository();
  const useCase = useMemo(() => new Get{{Module}}ByIdUseCase(repository), [repository]);
  return useQuery({
    queryKey: [QUERY_KEY, id],
    queryFn: () =>
      useCase.execute(id).then((result) => {
        if ('left' in result) throw new Error(result.left.message);
        return result.right;
      }),
    enabled: !!id,
  });
}

// #if features.search
export function use{{Module}}Search(query: string): UseQueryResult<{{Module}}Entity[], Error> {
  const repository = use{{Module}}Repository();
  const useCase = useMemo(() => new Search{{Module}}sUseCase(repository), [repository]);
  return useQuery({
    queryKey: [QUERY_KEY, 'search', query],
    queryFn: () =>
      useCase.execute(query).then((result) => {
        if ('left' in result) throw new Error(result.left.message);
        return result.right;
      }),
    enabled: query.trim().length > 0,
  });
}
// #endif

// ---------------------------------------------------------------------------
// Mutations
// ---------------------------------------------------------------------------

interface MutationCallbacks {
  onSuccess?: (message: string) => void;
}

export function use{{Module}}Mutations({ onSuccess: onSuccessCallback }: MutationCallbacks = {}) {
  const queryClient = useQueryClient();
  const repository = use{{Module}}Repository();

  /// Stable use-case instances — one per hook mount, not per mutation call.
  const addUseCase = useMemo(() => new Add{{Module}}UseCase(repository), [repository]);
  const updateUseCase = useMemo(() => new Update{{Module}}UseCase(repository), [repository]);
  const deleteUseCase = useMemo(() => new Delete{{Module}}UseCase(repository), [repository]);

  // ---- add ----------------------------------------------------------------
  const addMutation = useMutation({
    mutationFn: (entity: {{Module}}Entity) =>
      addUseCase.execute(entity).then((result) => {
        if ('left' in result) throw new Error(result.left.message);
        return result.right;
      }),
// #if features.optimistic_updates
    onMutate: async (newEntity) => {
      await queryClient.cancelQueries({ queryKey: [QUERY_KEY] });
      const snapshot = queryClient.getQueryData<{{Module}}Entity[]>([QUERY_KEY]);
      queryClient.setQueryData<{{Module}}Entity[]>([QUERY_KEY], (old = []) => [
        ...old,
        newEntity,
      ]);
      return { snapshot };
    },
    onError: (_err, _vars, context) => {
      if (context?.snapshot !== undefined) {
        queryClient.setQueryData([QUERY_KEY], context.snapshot);
      }
    },
    onSettled: () => queryClient.invalidateQueries({ queryKey: [QUERY_KEY] }),
// #else
    onSuccess: () => queryClient.invalidateQueries({ queryKey: [QUERY_KEY] }),
// #endif
// #if features.success_feedback
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: [QUERY_KEY] });
      onSuccessCallback?.('{{Module}} added');
    },
// #endif
  });

  // ---- update -------------------------------------------------------------
  const updateMutation = useMutation({
    mutationFn: (entity: {{Module}}Entity) =>
      updateUseCase.execute(entity).then((result) => {
        if ('left' in result) throw new Error(result.left.message);
        return result.right;
      }),
// #if features.optimistic_updates
    onMutate: async (updated) => {
      await queryClient.cancelQueries({ queryKey: [QUERY_KEY] });
      const snapshot = queryClient.getQueryData<{{Module}}Entity[]>([QUERY_KEY]);
      queryClient.setQueryData<{{Module}}Entity[]>([QUERY_KEY], (old = []) =>
        old.map((e) => (e.id === updated.id ? updated : e)),
      );
      return { snapshot };
    },
    onError: (_err, _vars, context) => {
      if (context?.snapshot !== undefined) {
        queryClient.setQueryData([QUERY_KEY], context.snapshot);
      }
    },
    onSettled: () => queryClient.invalidateQueries({ queryKey: [QUERY_KEY] }),
// #else
    onSuccess: () => queryClient.invalidateQueries({ queryKey: [QUERY_KEY] }),
// #endif
// #if features.success_feedback
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: [QUERY_KEY] });
      onSuccessCallback?.('{{Module}} updated');
    },
// #endif
  });

  // ---- delete -------------------------------------------------------------
  const deleteMutation = useMutation({
    mutationFn: (id: string) =>
      deleteUseCase.execute(id).then((result) => {
        if ('left' in result) throw new Error(result.left.message);
        return result.right;
      }),
// #if features.optimistic_updates
    onMutate: async (id) => {
      await queryClient.cancelQueries({ queryKey: [QUERY_KEY] });
      const snapshot = queryClient.getQueryData<{{Module}}Entity[]>([QUERY_KEY]);
      queryClient.setQueryData<{{Module}}Entity[]>([QUERY_KEY], (old = []) =>
        old.filter((e) => e.id !== id),
      );
      return { snapshot };
    },
    onError: (_err, _vars, context) => {
      if (context?.snapshot !== undefined) {
        queryClient.setQueryData([QUERY_KEY], context.snapshot);
      }
    },
    onSettled: () => queryClient.invalidateQueries({ queryKey: [QUERY_KEY] }),
// #else
    onSuccess: () => queryClient.invalidateQueries({ queryKey: [QUERY_KEY] }),
// #endif
// #if features.success_feedback
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: [QUERY_KEY] });
      onSuccessCallback?.('{{Module}} deleted');
    },
// #endif
  });

  return {
    add: addMutation,
    update: updateMutation,
    delete: deleteMutation,
  };
}
