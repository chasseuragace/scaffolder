/// App shell. Driven entirely by the generated feature registry —
/// `allDescriptors` powers navigation, `routes` powers routing. Adding a
/// feature never requires editing this file.
///
/// Generated ONCE for a fresh project (preserve: true). If you already have an
/// App component, consume `routes` (e.g. `useRoutes(routes)`) and
/// `allDescriptors` from the registry wherever your shell lives instead.
import { Link, useRoutes } from 'react-router-dom';
import { allDescriptors, routes } from './core/routing/feature-registry';

export default function App() {
  const element = useRoutes([{ path: '/', element: <Home /> }, ...routes]);

  return (
    <div>
      <nav
        style={{
          display: 'flex',
          gap: '1rem',
          padding: '0.75rem 1rem',
          borderBottom: '1px solid #ddd',
        }}
      >
        <Link to="/">Home</Link>
        {allDescriptors.map((d) => (
          <Link key={d.id} to={d.path}>
            {d.title}
          </Link>
        ))}
      </nav>
      <main style={{ padding: '1rem' }}>{element}</main>
    </div>
  );
}

function Home() {
  return (
    <section>
      <h1>App</h1>
      {allDescriptors.length === 0 ? (
        <p>No features generated yet.</p>
      ) : (
        <ul>
          {allDescriptors.map((d) => (
            <li key={d.id}>
              <Link to={d.path}>{d.title}</Link>
            </li>
          ))}
        </ul>
      )}
    </section>
  );
}
