/// Application entry point.
///
/// Generated ONCE for a fresh project (preserve: true — never overwritten, so
/// an existing app's entry point is safe). It wires the three cross-cutting
/// providers every generated feature relies on:
///   - QueryClientProvider  — TanStack Query cache for the feature hooks
///   - FeatureProviders     — composes every feature's repository provider
///   - BrowserRouter        — routing for the generated route table
///
/// Adding a feature never requires editing this file. If you already have an
/// entry point, mount <FeatureProviders> around your router instead (see the
/// generator skill, "midway an existing app").
import { StrictMode } from 'react';
import { createRoot } from 'react-dom/client';
import { BrowserRouter } from 'react-router-dom';
import { QueryClient, QueryClientProvider } from '@tanstack/react-query';
import App from './App';
import { FeatureProviders } from './core/routing/feature-registry';

const queryClient = new QueryClient();

createRoot(document.getElementById('root')!).render(
  <StrictMode>
    <QueryClientProvider client={queryClient}>
      <FeatureProviders>
        <BrowserRouter>
          <App />
        </BrowserRouter>
      </FeatureProviders>
    </QueryClientProvider>
  </StrictMode>,
);
