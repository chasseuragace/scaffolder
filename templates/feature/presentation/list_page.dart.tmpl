import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';

import '../../../../core/errors/failure_messages.dart';
import '../../../../core/widgets/empty_view.dart';
import '../../../../core/widgets/error_view.dart';
// #if features.shimmer_loading
import '../../../../core/widgets/shimmer_tile.dart';
// #endif
import '../providers/{{module_snake}}_providers.dart';
import '../widgets/{{module_snake}}_item_tile.dart';
// #if features.forms
import '../widgets/{{module_snake}}_form_dialog.dart';
// #endif
// #if features.search
import '../widgets/{{module_snake}}_search_delegate.dart';
// #endif

class {{Module}}ListPage extends ConsumerStatefulWidget {
  const {{Module}}ListPage({super.key});

  @override
  ConsumerState<{{Module}}ListPage> createState() => _{{Module}}ListPageState();
}

class _{{Module}}ListPageState extends ConsumerState<{{Module}}ListPage> {
  // #if features.pagination
  final _scroll = ScrollController();

  @override
  void initState() {
    super.initState();
    _scroll.addListener(_maybeLoadMore);
  }

  void _maybeLoadMore() {
    if (!_scroll.hasClients) return;
    final pos = _scroll.position;
    if (pos.pixels > pos.maxScrollExtent - 200) {
      ref.read({{module}}ListProvider.notifier).loadMore();
    }
  }

  @override
  void dispose() {
    _scroll.removeListener(_maybeLoadMore);
    _scroll.dispose();
    super.dispose();
  }
  // #endif

  @override
  Widget build(BuildContext context) {
    final state = ref.watch({{module}}ListProvider);
    // #if features.pagination
    final hasMore = ref.watch({{module}}HasMoreProvider);
    // #endif

    // Mutation feedback: surface failed add/edit/remove as a SnackBar
    // without dropping the whole page into an error state.
    ref.listen<Object?>({{module}}MutationErrorProvider, (_, error) {
      if (error == null) return;
      final messenger = ScaffoldMessenger.maybeOf(context);
      messenger
        ?..hideCurrentSnackBar()
        ..showSnackBar(
          SnackBar(
            content: Text(failureToMessage(error)),
            behavior: SnackBarBehavior.floating,
            action: SnackBarAction(
              label: 'Dismiss',
              onPressed: () => messenger.hideCurrentSnackBar(),
            ),
          ),
        );
      ref.read({{module}}MutationErrorProvider.notifier).state = null;
    });

    return Scaffold(
      appBar: AppBar(
        title: const Text('{{Module}}s'),
        actions: [
          // #if features.search
          IconButton(
            icon: const Icon(Icons.search),
            tooltip: 'Search',
            onPressed: () => showSearch(
              context: context,
              delegate: {{Module}}SearchDelegate(ref),
            ),
          ),
          // #endif
          IconButton(
            icon: const Icon(Icons.refresh),
            tooltip: 'Refresh',
            onPressed: () =>
                ref.read({{module}}ListProvider.notifier).refresh(),
          ),
        ],
      ),
      body: state.when(
        loading: () =>
            // #if features.shimmer_loading
            ShimmerTile.list(),
            // #else
            const Center(child: CircularProgressIndicator()),
            // #endif
        error: (e, _) => ErrorView(
          message: e.toString(),
          onRetry: () =>
              ref.read({{module}}ListProvider.notifier).refresh(),
        ),
        data: (items) => items.isEmpty
            ? const EmptyView(message: 'No {{Module}}s yet')
            : RefreshIndicator(
                onRefresh: () =>
                    ref.read({{module}}ListProvider.notifier).refresh(),
                child: ListView.separated(
                  // #if features.pagination
                  controller: _scroll,
                  itemCount: items.length + (hasMore ? 1 : 0),
                  // #else
                  itemCount: items.length,
                  // #endif
                  separatorBuilder: (_, __) => const Divider(height: 1),
                  itemBuilder: (context, i) {
                    // #if features.pagination
                    if (i >= items.length) {
                      return const Padding(
                        padding: EdgeInsets.symmetric(vertical: 16),
                        child: Center(child: CircularProgressIndicator()),
                      );
                    }
                    // #endif
                    return {{Module}}ItemTile(item: items[i]);
                  },
                ),
              ),
      ),
      // #if features.forms
      floatingActionButton: FloatingActionButton(
        tooltip: 'Add {{Module}}',
        onPressed: () => {{Module}}FormDialog.show(context),
        child: const Icon(Icons.add),
      ),
      // #endif
    );
  }
}
