import '../../domain/entities/{{module_snake}}_entity.dart';

/// Data-layer model for {{Module}}. Mirrors the on-the-wire shape and
/// provides toEntity / toJson conversions.
class {{Module}}Model {
  const {{Module}}Model({
    required this.id,
    this.name,
    this.description,
    this.createdAt,
    this.updatedAt,
  });

  final String id;
  final String? name;
  final String? description;
  final DateTime? createdAt;
  final DateTime? updatedAt;

  // #if features.json_serialization
  factory {{Module}}Model.fromJson(Map<String, dynamic> json) {
    return {{Module}}Model(
      id: json['id'] as String,
      name: json['name'] as String?,
      description: json['description'] as String?,
      createdAt: json['created_at'] is String
          ? DateTime.parse(json['created_at'] as String)
          : null,
      updatedAt: json['updated_at'] is String
          ? DateTime.parse(json['updated_at'] as String)
          : null,
    );
  }

  Map<String, dynamic> toJson() => {
        'id': id,
        'name': name,
        'description': description,
        'created_at': createdAt?.toIso8601String(),
        'updated_at': updatedAt?.toIso8601String(),
      };
  // #endif

  {{Module}}Entity toEntity() => {{Module}}Entity(
        id: id,
        name: name,
        description: description,
        createdAt: createdAt,
        updatedAt: updatedAt,
      );

  factory {{Module}}Model.fromEntity({{Module}}Entity e) => {{Module}}Model(
        id: e.id,
        name: e.name,
        description: e.description,
        createdAt: e.createdAt,
        updatedAt: e.updatedAt,
      );

  // #if features.mock_data_generation
  static const List<String> _names = [
    'Sample {{Module}} Alpha',
    'Test {{Module}} Beta',
    'Demo {{Module}} Gamma',
    'Mock {{Module}} Delta',
    'Example {{Module}} Epsilon',
  ];
  static const List<String> _descriptions = [
    'A first sample for {{Module}}',
    'A second sample for {{Module}}',
    'A third sample for {{Module}}',
  ];

  /// Deterministic dummy. Pass [seed] for reproducible variety.
  factory {{Module}}Model.dummy({String? id, int seed = 0}) {
    final s = seed.abs();
    return {{Module}}Model(
      id: id ?? '{{module_snake}}_$s',
      name: _names[s % _names.length],
      description: _descriptions[s % _descriptions.length],
      createdAt: DateTime(2024, 1, 1).add(Duration(days: s % 365)),
      updatedAt: DateTime(2024, 1, 1).add(Duration(days: (s % 365) + 1)),
    );
  }

  static List<{{Module}}Model> dummyList(int count) =>
      List.generate(count, (i) => {{Module}}Model.dummy(seed: i));
  // #endif
}
